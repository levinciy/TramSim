  - {fileID: 1886899445}
  stepMessages:
  - "\u0414\u043E\u0431\u0440\u043E \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u0442\u044C!
    \u0417\u0434\u0435\u0441\u044C \u0432\u044B \u043E\u0441\u0432\u043E\u0438\u0442\u0435
    \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435 \u0442\u0440\u0430\u043C\u0432\u0430\u0435\u043C."
  - "\u0414\u0432\u0438\u0436\u0435\u043D\u0438\u0435 \u0432\u043F\u0435\u0440\u0451\u0434:
    \u0443\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0439\u0442\u0435 <color=#00FF00>W</color>."
  - "\u0422\u043E\u0440\u043C\u043E\u0436\u0435\u043D\u0438\u0435: \u043D\u0430\u0436\u043C\u0438\u0442\u0435
    <color=#FF0000>S</color>."
  - "\u0417\u0432\u043E\u043D\u043E\u043A: \u0443\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0439\u0442\u0435
    <color=#FFFF00>H</color>."
  - "\u0421\u0442\u0440\u0435\u043B\u043A\u0438: <color=#00FFFF>N</color> (\u043D\u0435\u0439\u0442\u0440\u0430\u043B\u044C),
    <color=#00FFFF>L</color> (\u0432\u043B\u0435\u0432\u043E), <color=#00FFFF>D</color>
    (\u0432\u043F\u0440\u0430\u0432\u043E)."
  - "\u0420\u0435\u0432\u0435\u0440\u0441: <color=#FF8000>E</color>. \u0412\u043D\u0438\u043C\u0430\u043D\u0438\u0435:
    \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0435\u0441\u044C \u043F\u0435\u0440\u0435\u0434
    \u0432\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435\u043C!"
  - "\u041E\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0430: \u043F\u0440\u0438 \u043F\u0440\u043E\u0435\u0437\u0434\u0435
    \u0447\u0435\u0440\u0435\u0437 \u0437\u043E\u043D\u0443 \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0438
    \u2014 \u0441\u0431\u0440\u043E\u0441\u044C\u0442\u0435 \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C
    \u0434\u043E 0."
